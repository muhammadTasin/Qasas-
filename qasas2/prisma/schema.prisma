generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReactionType {
  LOVE
  SORROW
  ANGRY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  stories       Story[]
  reactions     Reaction[]
  comments      Comment[]
  storyViews    StoryView[]
  accounts      Account[]
  sessions      Session[]
}

model Story {
  id               String      @id @default(cuid())
  authorId         String
  title            String
  content          String
  estimatedReadTimeMinutes Int @default(1)
  totalReadSeconds Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  author           User        @relation(fields: [authorId], references: [id])
  reactions        Reaction[]
  comments         Comment[]
  views            StoryView[]

  @@index([authorId])
  @@index([createdAt])
}

model Reaction {
  id        String       @id @default(cuid())
  storyId   String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  story     Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@unique([storyId, userId])
  @@index([storyId])
}

model Comment {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  body      String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([storyId])
  @@index([createdAt])
}

model StoryView {
  id               String   @id @default(cuid())
  storyId          String
  visitorId        String?
  ipHash           String?
  userId           String?
  userAgent        String?
  deviceType       String?
  os               String?
  browser          String?
  country          String?
  region           String?
  city             String?
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @updatedAt
  totalReadSeconds Int      @default(0)
  story            Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id])

  @@unique([storyId, visitorId])
  @@unique([storyId, ipHash])
  @@index([storyId])
  @@index([userId])
  @@index([lastSeenAt])
}

model SiteVisitor {
  id          String   @id @default(cuid())
  visitorId   String?
  ipHash      String?
  userAgent   String?
  deviceType  String?
  os          String?
  browser     String?
  country     String?
  region      String?
  city        String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@unique([visitorId])
  @@unique([ipHash])
  @@index([lastSeenAt])
  @@index([firstSeenAt])
}

model SiteVisitEvent {
  id        String   @id @default(cuid())
  visitorId String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
